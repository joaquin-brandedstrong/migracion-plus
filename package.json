{
  "name": "migracionplus-academy",
  "private": true,
  "version": "0.1.0",
  "description": "Bilingual digital learning platform + book store for legal/migration education",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:migrate": "npm run migrate -w @migracionplus/db",
    "db:seed": "npm run seed -w @migracionplus/db",
    "db:reset": "npm run reset -w @migracionplus/db"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  }
}
