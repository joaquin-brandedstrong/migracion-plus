# =============================================================================
# Migración Plus Academy · Environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_DEFAULT_LOCALE=es

# Demo credentials shown by the "Use demo credentials" button on /iniciar-sesion.
# Defaults match what packages/db/scripts/seed.ts creates. Override here if you
# want the demo login to point at a different user.
NEXT_PUBLIC_DEMO_EMAIL=demo@migracionplus.academy
NEXT_PUBLIC_DEMO_PASSWORD=Demo2026!

# --- Supabase (https://supabase.com/dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Convenience aliases for the seed script
SUPABASE_URL=
SEED_ADMIN_EMAIL=admin@migracionplus.com
SEED_ADMIN_PASSWORD=

# --- Stripe (https://dashboard.stripe.com) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- PayPal (https://developer.paypal.com) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# --- OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=

# --- Twilio (https://console.twilio.com) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# --- Email (Resend, https://resend.com/api-keys) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@migracionplus.academy

# --- Video (pick ONE of the following) ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# - or -
CLOUDFLARE_STREAM_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=

# --- Amazon affiliate ---
AMAZON_AFFILIATE_TAG=

# --- Monitoring ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
